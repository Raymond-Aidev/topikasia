# Server
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgresql://topik:YOUR_PASSWORD@db:5432/topikibt

# JWT (must be 32+ characters)
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
ADMIN_JWT_SECRET=change-this-admin-secret-string-at-least-32-chars
JWT_EXPIRES_IN=8h
ADMIN_JWT_EXPIRES_IN=12h

# Frontend URL (CORS)
FRONTEND_URL=https://www.topikasia.com

# AWS S3 (optional, mock if not set)
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=topikasia-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Exam Config
EXAM_COUNTDOWN_SECONDS=10
EXAM_LATE_GRACE_SECONDS=30
