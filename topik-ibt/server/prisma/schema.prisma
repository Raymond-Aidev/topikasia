generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── 어드민 계정 ──────────────────────────────────────────────
model AdminUser {
  id           String    @id @default(cuid())
  loginId      String    @unique
  passwordHash String
  name         String
  role         AdminRole
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdExaminees Examinee[]
  uploadedExamSets ExamSet[]
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  PROCTOR
  QUESTION_AUTHOR
}

// ─── 응시자 ───────────────────────────────────────────────────
model Examinee {
  id                 String         @id @default(cuid())
  loginId            String         @unique
  passwordHash       String
  name               String
  registrationNumber String         @unique
  seatNumber         Int?
  photoUrl           String?
  institutionName    String?
  examRoomName       String?
  status             ExamineeStatus @default(ACTIVE)
  loginFailCount     Int            @default(0)
  assignedExamSetId  String?

  assignedExamSet ExamSet?      @relation(fields: [assignedExamSetId], references: [id], onDelete: SetNull)
  createdBy       AdminUser     @relation(fields: [createdById], references: [id])
  createdById     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  examSessions  ExamSession[]
  scores        Score[]
  lmsAnalyses   LmsAnalysis[]
}

enum ExamineeStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

// ─── 시험세트 ─────────────────────────────────────────────────
model ExamSet {
  id               String        @id @default(cuid())
  examSetNumber    String        @unique
  name             String
  examType         ExamType
  description      String?
  status           ExamSetStatus @default(DRAFT)
  sectionsJson     Json
  snapshotJson     Json?
  scheduledStartAt DateTime?
  uploadedAt       DateTime?
  uploadedBy       AdminUser?    @relation(fields: [uploadedById], references: [id])
  uploadedById     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  assignedExaminees Examinee[]
  examSessions      ExamSession[]
  scores            Score[]
  examSchedules     ExamSchedule[]
}

enum ExamType {
  TOPIK_I
  TOPIK_II
}

enum ExamSetStatus {
  DRAFT
  UPLOADED
  ACTIVE
  ARCHIVED
}

// ─── 응시 세션 ────────────────────────────────────────────────
model ExamSession {
  id                  String        @id @default(cuid())
  examineeId          String
  examSetId           String
  status              SessionStatus @default(IN_PROGRESS)
  sectionProgressJson Json
  startedAt           DateTime      @default(now())
  completedAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  examinee Examinee    @relation(fields: [examineeId], references: [id], onDelete: Cascade)
  examSet  ExamSet     @relation(fields: [examSetId], references: [id])
  answers  Answer[]
  score    Score?
  explanations QuestionExplanation[]
  lmsAnalysis  LmsAnalysis?
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

// ─── 답안 ─────────────────────────────────────────────────────
model Answer {
  id              String      @id @default(cuid())
  sessionId       String
  questionBankId  String
  section         String
  questionIndex   Int
  answerJson      Json
  savedAt         DateTime    @default(now())
  submittedAt     DateTime?
  isAutoSubmitted Boolean     @default(false)

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionBankId])
}

// ─── 성적 ───────────────────────────────────────────────────
model Score {
  id              String       @id @default(cuid())
  sessionId       String       @unique
  examineeId      String
  examSetId       String
  examType        ExamType
  sectionScores   Json         // { LISTENING: { raw, scaled, maxScore, autoGraded }, ... }
  totalScore      Int
  maxTotalScore   Int          // 200 (TOPIK_I) or 300 (TOPIK_II)
  grade           Int?         // 1~6급
  gradingStatus   GradingStatus @default(PENDING)
  isPublished     Boolean      @default(false)
  publishedAt     DateTime?
  publishedById   String?
  gradedAt        DateTime?
  gradedById      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  session   ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  examinee  Examinee    @relation(fields: [examineeId], references: [id], onDelete: Cascade)
  examSet   ExamSet     @relation(fields: [examSetId], references: [id])

  @@index([examineeId])
  @@index([examSetId])
  @@index([gradingStatus])
}

enum GradingStatus {
  PENDING            // 채점 전
  AUTO_GRADED        // 자동채점 완료 (쓰기 수동채점 대기)
  FULLY_GRADED       // 전체 채점 완료
}

// ─── LMS: 문제 해설 캐시 ────────────────────────────────────
model QuestionExplanation {
  id             String   @id @default(cuid())
  questionBankId String
  sessionId      String
  examineeAnswer Json?
  correctAnswer  Json?
  explanation    String   @db.Text
  llmModel       String   // e.g., "gpt-4o", "claude-sonnet-4-5"
  generatedAt    DateTime @default(now())

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionBankId])
  @@index([questionBankId])
}

// ─── LMS: 분석 스냅샷 ──────────────────────────────────────
model LmsAnalysis {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  examineeId     String
  typeBreakdown  Json     // { MCQ_SINGLE: { total, correct, accuracy }, ... }
  strengths      Json     // ["type1", "type2"]
  weaknesses     Json     // ["type3"]
  createdAt      DateTime @default(now())

  session  ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  examinee Examinee    @relation(fields: [examineeId], references: [id], onDelete: Cascade)

  @@index([examineeId])
}

// ─── 접수 회원 ─────────────────────────────────────────────────
model RegistrationUser {
  id           String    @id @default(dbgenerated("gen_random_uuid()::text"))
  email        String    @unique
  passwordHash String
  name         String
  phone        String?
  isVerified   Boolean   @default(false)
  verifyCode   String?
  verifyExpiry DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())

  registrations Registration[]
}

// ─── 시험 일정 ─────────────────────────────────────────────────
model ExamSchedule {
  id                  String         @id @default(dbgenerated("gen_random_uuid()::text"))
  examName            String
  examRound           Int
  examType            ExamType
  examDate            DateTime
  registrationStartAt DateTime
  registrationEndAt   DateTime
  venues              Json           @default("[]")
  maxCapacity         Int
  currentCount        Int            @default(0)
  status              ScheduleStatus @default(OPEN)
  examSetId           String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @default(now())

  examSet       ExamSet?       @relation(fields: [examSetId], references: [id], onDelete: SetNull)
  registrations Registration[]
}

enum ScheduleStatus {
  OPEN
  CLOSED
  FULL
}

// ─── 접수 신청 ─────────────────────────────────────────────────
model Registration {
  id            String             @id @default(dbgenerated("gen_random_uuid()::text"))
  userId        String
  scheduleId    String
  examType      ExamType
  englishName   String
  birthDate     DateTime
  gender        Gender
  photoUrl      String?
  venueId       String
  venueName     String
  contactPhone  String?
  address       String?
  status        RegistrationStatus @default(PENDING)
  examineeId    String?
  rejectionNote String?
  approvedAt    DateTime?
  approvedById  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @default(now())

  user     RegistrationUser @relation(fields: [userId], references: [id], onDelete: Restrict)
  schedule ExamSchedule     @relation(fields: [scheduleId], references: [id], onDelete: Restrict)

  @@unique([userId, scheduleId])
  @@index([status])
  @@index([scheduleId])
}

enum Gender {
  MALE
  FEMALE
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ─── 감사 로그 ────────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  action     String
  targetType String
  targetId   String
  detail     Json?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([action, createdAt])
}
